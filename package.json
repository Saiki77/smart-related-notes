{
  "name": "smart-related-notes",
  "version": "1.13.0",
  "description": "Surface notes ranked by local semantic similarity to the one you're reading, as a sidebar card stack.",
  "main": "main.js",
  "scripts": {
    "gen-ort": "node gen-ort.mjs",
    "predev": "node gen-ort.mjs",
    "dev": "node esbuild.config.mjs",
    "prebuild": "node gen-ort.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "prelint": "node gen-ort.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "bench": "node --experimental-strip-types bench/at-rest.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "embeddings",
    "semantic",
    "related"
  ],
  "author": "Saiki77",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "3.7.6",
    "onnxruntime-web": "1.22.0-dev.20250409-89f8206ba4"
  },
  "devDependencies": {
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.13.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.1"
  }
}
